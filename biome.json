{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "!**/.agent",
      "!**/.agents",
      "!**/.claude",
      "!**/.codex",
      "!**/.ryu-worktrees",
      "!**/.next",
      "!**/dist",
      "!**/target",
      "!**/out",
      "!**/dist-electron",
      "!**/.turbo",
      "!**/.nx",
      "!**/dev-dist",
      "!**/.zed",
      "!**/.vscode",
      "!**/routeTree.gen.ts",
      "!**/src-tauri",
      "!**/.nuxt",
      "!bts.jsonc",
      "!**/.expo",
      "!**/.wrangler",
      "!**/.alchemy",
      "!**/.svelte-kit",
      "!**/wrangler.jsonc",
      "!**/.source",
      "!**/convex/_generated",
      "!apps/core/Python",
      "!apps/fumadocs",
      "!apps/raycast",
      "!**/.wxt",
      "!apps/web/public/compare-logos",
      "!apps/tui/components/ui",
      "!apps/tui/hooks",
      "!apps/tui/lib"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noNestedComponentDefinitions": "off",
        "noUndeclaredVariables": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedVariables": "off",
        "noUndeclaredDependencies": "off",
        "noUnresolvedImports": "off",
        "useJsxKeyInIterable": "off",
        "useHookAtTopLevel": "off",
        "useExhaustiveDependencies": "off",
        "useImageSize": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "noArguments": "off",
        "noCommaOperator": "off",
        "noExcessiveCognitiveComplexity": "off",
        "noForEach": "off",
        "noVoid": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noImgElement": "off",
        "noNamespaceImport": "off",
        "useTopLevelRegex": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noAlert": "off",
        "noBitwiseOperators": "off",
        "noDocumentCookie": "off",
        "noDuplicateProperties": "off",
        "noEmptyBlockStatements": "off",
        "noEvolvingTypes": "off",
        "noExplicitAny": "off",
        "noImplicitAnyLet": "off",
        "noImportCycles": "off",
        "noNonNullAssertedOptionalChain": "off",
        "useAwait": "off",
        "useIterableCallbackReturn": "off"
      },
      "a11y": {
        "noLabelWithoutControl": "off",
        "noNoninteractiveElementInteractions": "off",
        "noRedundantAlt": "off",
        "noStaticElementInteractions": "off",
        "noSvgWithoutTitle": "off",
        "useAltText": "off",
        "useAnchorContent": "off",
        "useAriaPropsForRole": "off",
        "useAriaPropsSupportedByRole": "off",
        "useButtonType": "off",
        "useFocusableInteractive": "off",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off",
        "useMediaCaption": "off",
        "useSemanticElements": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "nursery": {
        "useSortedClasses": {
          "level": "warn",
          "fix": "safe",
          "options": {
            "functions": ["clsx", "cva", "cn"]
          }
        }
      },
      "style": {
        "noParameterAssign": "error",
        "useAsConstAssertion": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "noExportedImports": "off",
        "noNamespace": "off",
        "useFilenamingConvention": "off",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "noDescendingSpecificity": "off",
        "noNestedTernary": "off",
        "noNonNullAssertion": "off",
        "noParameterProperties": "off",
        "noSubstr": "off",
        "useConsistentMemberAccessibility": "off",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error",
        "useDefaultSwitchClause": "off",
        "useForOf": "off"
      }
    }
  },
  "javascript": {
    "globals": ["Bun"],
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["apps/island/**", "packages/command/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnresolvedImports": "off"
          },
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/tui/src/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnresolvedImports": "off"
          },
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/native/hooks/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["crates/sdk/napi/index.js"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "apps/desktop/components/agent-elements/**",
        "apps/desktop/components/loading-ui/wave.tsx"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/extension/.wxt/**"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    },
    {
      "includes": ["apps/native/app/**"],
      "linter": {
        "enabled": false
      },
      "formatter": {
        "enabled": false
      }
    }
  ],
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/next",
    "ultracite/biome/react"
  ]
}

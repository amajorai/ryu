{
  "name": "ryu",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "apps-store/*/ui",
      "apps-store/browser/sidecar",
      "crates/sdk/napi",
      "!apps/raycast"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "@better-auth/api-key": "1.5.2",
      "ai": "^6.0.3",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sileo": "latest",
      "@tanstack/react-form": "^1.28.0",
      "@polar-sh/better-auth": "^1.6.4",
      "@ai-sdk/react": "^3.0.3",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "@better-auth/expo": "1.5.2"
    }
  },
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-ports.mjs",
    "polar:provision": "bun run scripts/polar/provision-products.ts",
    "polar:provision-extras": "bun run scripts/polar/provision-extras.ts",
    "mirror:satellites": "bash tools/mirror-satellites.sh",
    "mirror:public": "bash tools/mirror-push.sh && bash tools/mirror-satellites.sh",
    "release:local": "bash scripts/release/release-local.sh",
    "publish:npm": "bash tools/publish-npm.sh",
    "publish:crates": "bash tools/publish-crates.sh",
    "dev": "turbo dev --concurrency=20 --continue",
    "kill-ports": "node scripts/free-ports.mjs",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "test:rust": "cargo test --manifest-path apps/core/Cargo.toml && cargo test --manifest-path apps/gateway/Cargo.toml && cargo test --manifest-path apps/cli/Cargo.toml && cargo test --manifest-path crates/sdk/core/Cargo.toml && cargo test --manifest-path crates/ghost/core/Cargo.toml && cargo test --manifest-path crates/ghost/shadow/Cargo.toml",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "migrate:list": "bun --filter server migrate:list",
    "migrate:up": "bun --filter server migrate:up",
    "migrate:down": "bun --filter server migrate:down",
    "migrate:create": "bun --filter server migrate:create",
    "dev:desktop": "turbo -F desktop dev",
    "dev:island": "turbo -F island dev",
    "dev:storyboard": "turbo -F storyboard dev",
    "dev:fumadocs": "turbo run dev --filter=fumadocs",
    "build:sdk": "turbo run build --filter=@ryuhq/sdk --filter=create-ryu-app --filter=@ryuhq/client",
    "dev:core": "turbo -F core dev",
    "dev:gateway": "turbo -F gateway dev",
    "dev:tts": "cd apps-store/voice/sidecar && python -m ryu_tts",
    "dev:unsloth": "cd apps-store/finetune/sidecar && python -m ryu_unsloth",
    "dev:cli": "cd apps/cli && cargo run",
    "clean": "turbo clean && bun run clean:rust",
    "clean:desktop": "turbo -F desktop clean",
    "clean:rust": "cargo clean --manifest-path apps/desktop/src-tauri/Cargo.toml; cargo clean --manifest-path apps/core/Cargo.toml; cargo clean --manifest-path apps/cli/Cargo.toml; cargo clean --manifest-path apps/gateway/Cargo.toml; cargo clean --manifest-path apps-store/predict/Cargo.toml; cargo clean --manifest-path apps-store/predict-spike/Cargo.toml; cargo clean --manifest-path apps/web/src-tauri/Cargo.toml; cargo clean --manifest-path crates/ghost/core/Cargo.toml; cargo clean --manifest-path crates/ghost/eyes/Cargo.toml; cargo clean --manifest-path crates/ghost/hands/Cargo.toml; cargo clean --manifest-path crates/ghost/shadow/Cargo.toml; cargo clean --manifest-path crates/sdk/core/Cargo.toml; cargo clean --manifest-path crates/sdk/ffi/Cargo.toml; cargo clean --manifest-path crates/sdk/napi/Cargo.toml; cargo clean --manifest-path crates/sdk/uniffi/Cargo.toml",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "env:export": "node scripts/env-sync.mjs export",
    "env:export:file": "node scripts/env-sync.mjs export --file --no-clipboard",
    "env:import": "node scripts/env-sync.mjs import",
    "env:import:file": "node scripts/env-sync.mjs import --file --force"
  },
  "dependencies": {
    "@ryu/env": "workspace:*",
    "dotenv": "catalog:",
    "mermaid": "^11.15.0",
    "next-themes": "^0.4.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@ryu/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "latest",
    "lint-staged": "latest",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.3.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "electron",
    "@takumi-rs/core",
    "takumi-js"
  ],
  "patchedDependencies": {
    "@expo/cli@55.0.16": "patches/@expo%2Fcli@55.0.16.patch"
  }
}

<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Smoke project for the Ryu C# binding. Globs BOTH this folder's .cs files into
    one assembly: the committed `Program.cs` smoke and the GENERATED (gitignored)
    `ryu_sdk.cs`. They must share an assembly because uniffi-bindgen-cs emits its
    types as `internal`.

    The native library `ryu_sdk_uniffi.dll` (built from crates/ryu-sdk-uniffi) is
    P/Invoked by `[DllImport("ryu_sdk_uniffi")]`; drop it beside this project (see
    README) and it is copied to the output dir so `dotnet run` resolves it.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>ryu_sdk_csharp_smoke</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <None Include="ryu_sdk_uniffi.dll" Condition="Exists('ryu_sdk_uniffi.dll')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>

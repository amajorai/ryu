# The importable package is GENERATED by uniffi-bindgen (see README + the
# sdk-bindings CI workflow), not committed. Only the packaging shell + smoke test
# are tracked. The one exception is the committed `__init__.py` that re-exports
# the generated module so `import ryu_sdk` resolves (un-ignored below).
/ryu_sdk/*
!/ryu_sdk/__init__.py
*.so
*.dylib
*.dll
__pycache__/
*.pyc
dist/
build/
*.egg-info/

{
	"name": "@ryu/apps",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Ryu Apps widget workspace: the shared frame-side bridge plus the built-in widget bundles (one self-contained HTML per app), embedded into Core.",
	"exports": {
		"./shared/*": "./src/shared/*"
	},
	"scripts": {
		"build": "bun scripts/build-all.ts",
		"gen": "bun scripts/build-all.ts && bun scripts/embed.ts",
		"gen:check": "bun scripts/embed.ts --check",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@ryu/config": "workspace:*",
		"@types/bun": "catalog:",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.2.0",
		"typescript": "^5",
		"vite": "^7.3.1",
		"vite-plugin-singlefile": "^2.3.0"
	}
}

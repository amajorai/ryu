{
  "name": "@ryu/sdk",
  "version": "0.0.1",
  "type": "module",
  "description": "Ryu developer SDK: typed builders and CLI for authoring plugin.json Plugin bundles",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "require": "./dist/manifest.cjs"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "ryu": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ryu/sdk-native": "workspace:*",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}

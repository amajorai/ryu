# Desktop (Tauri) Vite env — same keys as apps/webapp/.env.example.
# Copy to apps/desktop/.env for local dev.

# Core node the desktop app talks to.
VITE_CORE_URL=http://127.0.0.1:7980

# Identity / content plane (apps/server)
VITE_APP_BACKEND_URL=http://localhost:3000
VITE_APP_FRONTEND_URL=http://localhost:3001
VITE_APP_WEB_URL=http://localhost:3001

# Analytics — no-op when empty
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Crash reporting — no-op when empty
VITE_SENTRY_DSN=https://1371a855920ed833ba44d6292442d471@o4511706237304832.ingest.us.sentry.io/4511706239139840

VITE_APP_VERSION=0.0.1

# Baked into production desktop builds (vite build / tauri build).
# Without VITE_APP_* auth URLs, sign-in hits localhost:3000 on end-user machines.
# Observability keys match apps/web (.env) and amajorai/ryu-closed GitHub Variables.

VITE_CORE_URL=http://127.0.0.1:7980

VITE_APP_BACKEND_URL=https://api.ryuhq.com
VITE_APP_FRONTEND_URL=https://ryuhq.com
VITE_APP_WEB_URL=https://ryuhq.com

# PostHog — same project as apps/web (NEXT_PUBLIC_POSTHOG_*)
VITE_POSTHOG_KEY=phc_oVyGwGwKdHjRYiFMD2P2pPgt8Rr97RS3DSKMbyr5Qdv9
VITE_POSTHOG_HOST=https://us.i.posthog.com


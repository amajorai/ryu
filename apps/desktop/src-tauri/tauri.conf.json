{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ryu",
  "mainBinaryName": "Ryu",
  "identifier": "dev.ryu.desktop",
  "version": "0.0.9",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build:vite"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ryu",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "dragDropEnabled": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --use-fake-ui-for-media-stream"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdn.userjot.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http://localhost:* http://127.0.0.1:*; font-src 'self' data:; media-src 'self' blob: data: https:; worker-src 'self' blob:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:* http://*:7980 ws://localhost:* ws://127.0.0.1:* wss: https:; frame-src 'self' about: blob: http: https:; object-src 'none'; base-uri 'self'"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["ryu"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/amajorai/ryu/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3N0U5QkE0RTcyRUREODAKUldTQTNTN25wSnQrdHlTV2tpUmdQYUFpenBMUDJteGNuMHYybzV5NGIwRUdEbXdSWHBiT3RuR2QK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

# Dev-profile overrides — loaded by Vite ONLY in `development` mode (bun dev),
# never in a production build. Keeps a `bun dev` webview talking to the DEV Core
# (RYU_PROFILE=dev → ~/.ryu-dev, every backend port +1000) instead of the installed
# prod Core on :7980, so a dev instance runs side-by-side with the installed app.

# Dev Core = profile::port(7980) = 7980 + 1000.
VITE_CORE_URL=http://127.0.0.1:8980

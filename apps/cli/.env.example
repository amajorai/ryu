# Ryu CLI (apps/cli) — environment configuration
#
# Legacy ratatui terminal client for Core (being succeeded by apps/tui). Device
# auth persists to ~/.ryu/auth.json. EVERYTHING here is OPTIONAL.

# Target Core node base URL. Default: http://localhost:7980
# RYU_CORE_URL=http://localhost:7980

# Control-plane (Better Auth) base URL for OAuth device flow. Default:
# http://localhost:3000
# RYU_AUTH_URL=http://localhost:3000

# Active org id for `ryu apply` / `ryu config` GitOps commands. Can also pass
# --org on the command line.
# RYU_ORG=

# Override the command used to launch the modern TUI (`ryu tui`). Escape hatch
# for packaged installs where the monorepo root is not discoverable.
# RYU_TUI_CMD=bun run --filter tui dev

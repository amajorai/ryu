# Ryu Gateway env vars
#
# The gateway's PRIMARY config is a TOML file (gateway.toml), resolved from the
# GATEWAY_CONFIG env var or, if unset, $config_dir/ryu/gateway.toml. Everything
# below is an OVERRIDE or a SECRET layered on top of that TOML: env vars win over
# the file, so you only need to set the handful that apply to your deployment.
#
# Copy this file to `.env` and uncomment the lines you need. Almost everything is
# optional, so every line is commented out by default. Booleans accept
# true/false/1/0. Leave provider keys unset to keep those providers disabled.

# ---------------------------------------------------------------------------
# Bind & config path
# ---------------------------------------------------------------------------
# Address the gateway HTTP server binds to. Default scheme is loopback:7981.
# GATEWAY_BIND=127.0.0.1:7981
# Absolute path to gateway.toml. Unset -> $config_dir/ryu/gateway.toml.
# GATEWAY_CONFIG=/path/to/gateway.toml

# ---------------------------------------------------------------------------
# Master key & internal secrets
# ---------------------------------------------------------------------------
# Bearer key that guards the gateway's admin/config surface. Set in any shared
# deployment; unset means loopback-only trust.
# GATEWAY_MASTER_KEY=change-me-master-key
# Shared secret Core presents to the gateway's internal credits endpoints (#486).
# RYU_CREDITS_INTERNAL_SECRET=change-me-credits-secret
# ed25519 signing key for marketplace publish (base64 32-byte seed). The
# production source of truth — set it so signatures survive restarts and are
# stable across replicas. When UNSET the gateway persists a dev key to
# $XDG_DATA_HOME/ryu/marketplace-signing-key (stable across local restarts).
# RYU_MARKETPLACE_SIGNING_KEY=
# Override the on-disk path of the dev-persisted signing key (only used when
# RYU_MARKETPLACE_SIGNING_KEY is unset).
# RYU_MARKETPLACE_SIGNING_KEY_PATH=
# Comma-separated allowlist of grants the gateway will sign/publish.
# RYU_MARKETPLACE_GRANT_ALLOWLIST=

# ---------------------------------------------------------------------------
# Control plane (managed / fleet mode)
# ---------------------------------------------------------------------------
# URL of the managed control plane that serves org policy + shared budgets.
# CONTROL_PLANE_URL=https://control.ryu.example
# API key this gateway uses to authenticate to the control plane.
# CONTROL_PLANE_KEY=
# Gateway key the policy layer presents to the control plane.
# GATEWAY_KEY=
# Shared budget id this gateway debits against in the control plane.
# CONTROL_PLANE_SHARED_BUDGET_ID=
# Marks this gateway as part of the managed fleet (multi-tenant data plane).
# RYU_GATEWAY_FLEET=false

# ---------------------------------------------------------------------------
# Core node link (tools, credits, channel replies)
# ---------------------------------------------------------------------------
# URL of the Core node the gateway calls back into. Default local: :7980.
# CORE_URL=http://127.0.0.1:7980
# Bearer token the gateway presents to Core.
# CORE_TOKEN=
# Core URL used by the built-in channel bots (falls back to the default local Core).
# RYU_CORE_URL=http://127.0.0.1:7980

# ---------------------------------------------------------------------------
# Provider keys & base URLs (upstream LLM / media providers)
# ---------------------------------------------------------------------------
# OpenAI-compatible provider.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic provider.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OpenRouter aggregator (provider upstream, not the user-level layer).
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=
# OPENROUTER_SITE_NAME=
# OPENROUTER_DATA_COLLECTION=deny
# OPENROUTER_SORT=
# Replicate (image/video/media).
# REPLICATE_API_KEY=
# REPLICATE_BASE_URL=https://api.replicate.com/v1
# fal.ai (image/media).
# FAL_API_KEY=
# FAL_BASE_URL=https://fal.run
# Modal (hosted inference).
# MODAL_API_KEY=
# MODAL_BASE_URL=
# Local OpenAI-compatible engine (e.g. llama.cpp on :8080).
# LOCAL_LLM_URL=http://127.0.0.1:8080/v1

# ---------------------------------------------------------------------------
# Firewall & smart routing
# ---------------------------------------------------------------------------
# Toggle the request firewall / DLP inspection.
# GATEWAY_FIREWALL_ENABLED=true
# Firewall action policy: block | warn | sanitize (aka redact). Default: block
# (a detected injection/secret/PII match rejects the request with a 403; set
# sanitize to redact-and-continue instead).
# GATEWAY_FIREWALL_POLICY=block
# Opt-in classifier-based model routing (Plane A). Fail-open.
# GATEWAY_SMART_ROUTING_ENABLED=false
# Cheap classifier model used to pick the downstream model.
# GATEWAY_SMART_ROUTING_MODEL=

# ---------------------------------------------------------------------------
# Tool execution
# ---------------------------------------------------------------------------
# Enable the gateway tool-search front + POST /v1/exec/tool.
# GATEWAY_TOOLS_ENABLED=true
# Approval mode for exec (e.g. auto / ask / never).
# RYU_EXEC_APPROVAL_MODE=auto

# ---------------------------------------------------------------------------
# Context compression sidecar
# ---------------------------------------------------------------------------
# GATEWAY_COMPRESSION_ENABLED=false
# GATEWAY_COMPRESSION_URL=
# GATEWAY_COMPRESSION_TOKEN=
# GATEWAY_COMPRESSION_TIMEOUT_MS=10000
# GATEWAY_COMPRESSION_MIN_MESSAGES=8

# ---------------------------------------------------------------------------
# Per-session token budget (#510)
# ---------------------------------------------------------------------------
# Token cap per session. 0 disables. gateway.toml [budgets.session] is primary.
# GATEWAY_SESSION_BUDGET_LIMIT=0
# Action on cap: notify / downgrade / restrict / stop.
# GATEWAY_SESSION_BUDGET_ACTION=notify

# ---------------------------------------------------------------------------
# Managed credits / metering (#486) — off by default, Core enables it
# ---------------------------------------------------------------------------
# GATEWAY_CREDITS_ENABLED=false
# GATEWAY_CREDITS_URL=
# Markup applied to metered spend, in basis points.
# GATEWAY_CREDITS_MARKUP_BPS=0
# Flat per-modality rates (micro-USD; 0 = free).
# GATEWAY_CREDITS_COST_PER_TOOL_CALL_MICRO_USD=0
# GATEWAY_CREDITS_COST_PER_IMAGE_MICRO_USD=0
# GATEWAY_CREDITS_COST_PER_VIDEO_MICRO_USD=0
# GATEWAY_CREDITS_COST_PER_TTS_MICRO_USD=0
# GATEWAY_CREDITS_COST_PER_STT_MICRO_USD=0
# Sandbox metering.
# GATEWAY_CREDITS_SANDBOX_MARKUP_BPS=0
# GATEWAY_CREDITS_SANDBOX_FREE_STORAGE_GIB=0
# Sandbox resource rates (nano-USD per second; 0 = free).
# GATEWAY_CREDITS_COST_PER_SANDBOX_VCPU_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_MEM_GIB_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_STORAGE_GIB_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_GPU_H200_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_GPU_H100_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_GPU_RTX_PRO_6000_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_GPU_RTX_5090_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_GPU_RTX_4090_SECOND_NANO_USD=0
# GATEWAY_CREDITS_COST_PER_SANDBOX_WINDOWS_VCPU_SECOND_NANO_USD=0
# What to do when a wallet is empty: notify / downgrade / restrict / stop.
# GATEWAY_CREDITS_WALLET_EMPTY_ACTION=stop
# Model to downgrade to when the wallet is empty (with the downgrade action).
# GATEWAY_CREDITS_WALLET_EMPTY_DOWNGRADE_TO=
# Refuse requests when the credits backend is unreachable (fail-closed).
# GATEWAY_CREDITS_FAIL_CLOSED=false

# ---------------------------------------------------------------------------
# Passthrough proxy (subscription-preserving Claude Code / Codex egress)
# ---------------------------------------------------------------------------
# Upstream the Anthropic (Claude Code) passthrough forwards to.
# RYU_PASSTHROUGH_ANTHROPIC_UPSTREAM=https://api.anthropic.com
# Upstream the Codex passthrough forwards to.
# RYU_PASSTHROUGH_CODEX_UPSTREAM=https://api.openai.com

# ---------------------------------------------------------------------------
# Mesh (cross-node tool egress)
# ---------------------------------------------------------------------------
# Enable Tailscale mesh. Fail-closed: refuses tokenless requests when on.
# RYU_MESH_ENABLED=false

# ---------------------------------------------------------------------------
# Observability (crash reporting & OTEL diagnostics)
# ---------------------------------------------------------------------------
# Crash reporting is opt-out; set false to disable.
# RYU_CRASH_REPORTS_ENABLED=true
# Sentry DSN (Ryu mirror first, then generic). Empty = no destination.
# RYU_SENTRY_DSN=
# SENTRY_DSN=
# Enable OTLP diagnostics export.
# RYU_DIAGNOSTICS_EXPORT_ENABLED=false
# OTLP collector endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OpenTelemetry semantic-convention stability opt-in.
# OTEL_SEMCONV_STABILITY_OPT_IN=

# ---------------------------------------------------------------------------
# Composio (tool provider for channel bots / workflows)
# ---------------------------------------------------------------------------
# COMPOSIO_API_KEY=
# COMPOSIO_ENTITY_ID=
# COMPOSIO_BASE_URL=https://backend.composio.dev

# ---------------------------------------------------------------------------
# Channel connectors (built-in bots)
# ---------------------------------------------------------------------------
# Setting a token enables that channel. Per-channel MODEL/SYSTEM_PROMPT/AGENT_ID/
# TEAM_ID/GROUP_REPLY_MODE tune behaviour. Allowlist a channel's chats with the
# global RYU_CHANNEL_ALLOWED_USERS or a per-platform RYU_CHANNEL_ALLOWED_USERS_<PLATFORM>.
# Default-CLOSED: with no allowlist configured, all inbound is refused unless
# RYU_CHANNEL_ALLOW_ALL=1 explicitly opts into accepting every chat.
# RYU_CHANNEL_ALLOWED_USERS=
# RYU_CHANNEL_ALLOWED_USERS_TELEGRAM=
# RYU_CHANNEL_ALLOW_ALL=

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_MODEL=
# TELEGRAM_SYSTEM_PROMPT=
# TELEGRAM_AGENT_ID=
# TELEGRAM_TEAM_ID=
# TELEGRAM_GROUP_REPLY_MODE=

# Slack
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_MODEL=
# SLACK_SYSTEM_PROMPT=
# SLACK_AGENT_ID=
# SLACK_TEAM_ID=
# SLACK_GROUP_REPLY_MODE=

# Discord
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_IDS=
# DISCORD_MODEL=
# DISCORD_SYSTEM_PROMPT=
# DISCORD_AGENT_ID=
# DISCORD_TEAM_ID=
# DISCORD_GROUP_REPLY_MODE=

# WhatsApp
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_WEBHOOK_BIND=
# WHATSAPP_WEBHOOK_PATH=
# WHATSAPP_GRAPH_VERSION=
# WHATSAPP_MODEL=
# WHATSAPP_SYSTEM_PROMPT=
# WHATSAPP_AGENT_ID=
# WHATSAPP_TEAM_ID=
# WHATSAPP_GROUP_REPLY_MODE=

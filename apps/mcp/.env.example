# Ryu MCP server (apps/mcp) — environment configuration
#
# Exposes a running Core node to any MCP host (Claude Desktop, Cursor, …).
# Device-auth login persists credentials to ~/.ryu/auth.json (shared with the
# CLI and desktop). EVERYTHING here is OPTIONAL.

# Target Core node base URL (no trailing slash). Default: http://127.0.0.1:7980
# RYU_CORE_URL=http://127.0.0.1:7980

# Optional bearer token for Core API routes (the node secret RYU_CORE_TOKEN).
# RYU_CORE_TOKEN=

# Control-plane (Better Auth) base URL for session validation during login.
# Default: http://localhost:3000
# RYU_AUTH_URL=http://localhost:3000

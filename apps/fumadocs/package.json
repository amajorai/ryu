{
  "name": "fumadocs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun run generate:docs && next build",
    "generate:docs": "bun ./scripts/generate-docs.ts",
    "dev": "next dev --port=4000",
    "start": "next start",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "clean": "rm -rf .next out build .source"
  },
  "dependencies": {
    "@scalar/api-client-react": "2.0.22",
    "@takumi-rs/image-response": "^0.71.7",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "10.10.3",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.15.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}

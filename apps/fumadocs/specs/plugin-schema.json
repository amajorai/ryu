{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ryuhq.com/schemas/plugin.json",
  "title": "Ryu Plugin Manifest",
  "description": "The plugin.json schema for Ryu apps. Defines runnables, permissions, activation events, and marketplace metadata.",
  "type": "object",
  "required": ["id", "name", "version"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Reverse-domain unique identifier (e.g. com.ryu.mail). Must be lowercase, dot-separated, path-traversal-safe.",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable display name.",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Semver version string (e.g. 1.0.0).",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.]+)?(\\+[\\w.]+)?$"
    },
    "ui_code_sha256": {
      "type": "string",
      "description": "Hex SHA-256 of bundled sandboxed UI code. Computed by ryu pack/ryu publish. Absent for manifest-only plugins."
    },
    "runnables": {
      "type": "array",
      "description": "The Runnables this plugin bundles.",
      "default": [],
      "items": {
        "$ref": "#/$defs/RunnableMeta"
      }
    },
    "permission_grants": {
      "type": "array",
      "description": "Permission declarations this plugin needs (e.g. mcp:web_search). Enforcement is the Gateway's responsibility.",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "companion": {
      "$ref": "#/$defs/CompanionSurface",
      "description": "Optional in-desktop overlay or sidebar panel surface."
    },
    "activation_events": {
      "type": "array",
      "description": "VS-Code-style activation events: *, onStartup, onChat, onCommand:<id>. Empty = eager.",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "contributes": {
      "$ref": "#/$defs/Contributes",
      "description": "Contribution points: turn hooks + declarative UI widgets."
    },
    "requires": {
      "$ref": "#/$defs/Requires",
      "description": "Plugin-to-plugin dependencies. Core resolves topological enable order."
    },
    "targets": {
      "type": "array",
      "description": "Host surfaces this plugin runs on. Empty = runs on every surface.",
      "default": [],
      "items": {
        "$ref": "#/$defs/Surface"
      }
    },
    "affiliate": {
      "$ref": "#/$defs/Affiliate",
      "description": "Marketplace affiliate terms (commission for referrers)."
    },
    "description": {
      "type": "string",
      "description": "Longer description shown in the marketplace detail dialog."
    },
    "tagline": {
      "type": "string",
      "description": "Short one-line pitch shown under the name."
    },
    "author": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "url": { "type": "string" }
          },
          "required": ["name"]
        }
      ],
      "description": "Publisher identity."
    },
    "homepage": {
      "type": "string",
      "description": "Project or marketing homepage URL."
    },
    "keywords": {
      "type": "array",
      "description": "Free-text search keywords.",
      "items": { "type": "string" }
    },
    "category": {
      "type": "string",
      "description": "Taxonomy category beyond the runnable kinds."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier."
    },
    "iconUrl": {
      "type": "string",
      "description": "Square logo/icon URL for the listing card."
    },
    "screenshots": {
      "type": "array",
      "description": "Ordered screenshot gallery URLs.",
      "items": { "type": "string" }
    },
    "privacyPolicyUrl": {
      "type": "string",
      "description": "Privacy policy URL."
    },
    "termsOfServiceUrl": {
      "type": "string",
      "description": "Terms of service URL."
    },
    "capabilities": {
      "type": "array",
      "description": "Human-readable capability strings. When omitted, derived from permission_grants.",
      "items": { "type": "string" }
    },
    "examplePrompts": {
      "type": "array",
      "description": "Example prompt chips shown on the marketplace detail page.",
      "items": { "type": "string" }
    },
    "setup": {
      "oneOf": [
        { "$ref": "#/$defs/SetupStep" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/SetupStep" }
        }
      ],
      "description": "Post-install configuration guide steps."
    }
  },
  "$defs": {
    "RunnableMeta": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable unique identifier (e.g. agent-researcher).",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "description": "Human-readable display name.",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["agent", "workflow", "tool", "skill", "companion"],
          "description": "The kind of Runnable."
        },
        "config": {
          "type": "object",
          "description": "Optional per-kind configuration blob. Schema varies by kind."
        }
      }
    },
    "RunnableKind": {
      "type": "string",
      "enum": ["agent", "workflow", "tool", "skill", "companion"]
    },
    "Surface": {
      "type": "string",
      "enum": ["gateway", "core", "desktop", "island", "mobile", "extension", "web", "cli"],
      "description": "A host surface the plugin can run on."
    },
    "CompanionSurface": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["panel", "overlay"],
          "description": "The companion surface type."
        },
        "position": {
          "type": "string",
          "enum": ["left", "right", "bottom"],
          "description": "Panel position (for panel type)."
        },
        "defaultOpen": {
          "type": "boolean",
          "description": "Whether the companion opens by default.",
          "default": false
        }
      }
    },
    "Contributes": {
      "type": "object",
      "description": "Contribution points for turn hooks and declarative UI.",
      "properties": {
        "turn_hooks": {
          "type": "array",
          "description": "Server-side turn hooks triggered on chat events.",
          "items": {
            "type": "object",
            "properties": {
              "event": {
                "type": "string",
                "enum": ["pre_turn", "post_turn", "on_tool_use", "on_session_start"],
                "description": "The hook event type."
              },
              "handler": {
                "type": "string",
                "description": "The handler function identifier."
              }
            }
          }
        },
        "composer_controls": {
          "type": "array",
          "description": "UI controls added to the chat composer.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "settings_tabs": {
          "type": "array",
          "description": "Custom settings tabs contributed to the desktop app.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "slash_commands": {
          "type": "array",
          "description": "Slash commands available in the chat input.",
          "items": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "widgets": {
          "type": "array",
          "description": "In-chat interactive widgets.",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "ui_entry": { "type": "string" }
            }
          }
        }
      }
    },
    "Requires": {
      "type": "object",
      "description": "Plugin dependencies and capability requirements.",
      "properties": {
        "apps": {
          "type": "array",
          "description": "Other plugin IDs this plugin depends on.",
          "items": { "type": "string" }
        },
        "capabilities": {
          "type": "array",
          "description": "Abstract capability requirements (e.g. rag, memory, tts). Resolved by the capability broker.",
          "items": {
            "type": "object",
            "properties": {
              "capability": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        },
        "grants": {
          "type": "array",
          "description": "Permission grants required from the Gateway.",
          "items": { "type": "string" }
        }
      }
    },
    "Affiliate": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "rule": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["percent", "flat"]
            },
            "value": {
              "type": "number",
              "minimum": 0,
              "description": "Basis points for percent (2000 = 20%) or minor units for flat."
            },
            "recurring": {
              "type": "boolean",
              "default": false
            },
            "durationMonths": {
              "type": "integer",
              "minimum": 1
            },
            "fundedBy": {
              "type": "string",
              "enum": ["platform", "seller"],
              "default": "platform"
            }
          }
        }
      }
    },
    "SetupStep": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Step title."
        },
        "description": {
          "type": "string",
          "description": "Step description or instructions."
        },
        "type": {
          "type": "string",
          "enum": ["info", "input", "select"],
          "description": "The step input type.",
          "default": "info"
        },
        "field": {
          "type": "string",
          "description": "The configuration field this step maps to."
        },
        "placeholder": {
          "type": "string",
          "description": "Placeholder text for input fields."
        }
      }
    }
  }
}

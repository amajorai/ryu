# Ryu TUI (apps/tui) — environment configuration
#
# Bun + OpenTUI terminal client for a running Core node. Mirrors apps/mcp target
# resolution. EVERYTHING here is OPTIONAL.

# Target Core node base URL (no trailing slash). Default: http://127.0.0.1:7980
# RYU_CORE_URL=http://127.0.0.1:7980

# Optional bearer token for Core API routes (the node secret RYU_CORE_TOKEN).
# RYU_CORE_TOKEN=

# Control-plane (Better Auth) base URL for the Account tab device-auth flow.
# Default: http://localhost:3000
# RYU_AUTH_URL=http://localhost:3000

{
  "id": "smart-intake-form",
  "name": "Smart Intake Form",
  "version": "1.0.0",
  "runnables": [
    {
      "id": "tool-appform-render",
      "name": "Render Form",
      "kind": "tool",
      "config": { "slug": "app.form__render" }
    },
    {
      "id": "tool-appform-submit",
      "name": "Submit Form",
      "kind": "tool",
      "config": { "slug": "app.form__submit" }
    }
  ],
  "contributes": {
    "widgets": [
      {
        "tool_id": "app.form__render",
        "uri": "ui://widget/smart-intake-form.html",
        "mime": "text/html+skybridge",
        "default_display_mode": "inline"
      }
    ]
  },
  "permission_grants": ["widget:render"]
}

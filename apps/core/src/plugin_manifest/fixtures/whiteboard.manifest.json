{
	"id": "com.ryu.whiteboard",
	"name": "Whiteboard",
	"version": "1.0.0",
	"runnables": [
		{
			"id": "whiteboard-companion",
			"name": "Whiteboard",
			"kind": "companion",
			"config": {
				"label": "Whiteboard",
				"ui_entry": "./dist/index.html",
				"ui_format": "html"
			}
		}
	],
	"requires": {
		"apps": [
			{
				"id": "com.ryu.spaces"
			}
		],
		"grants": ["spaces:docs"]
	},
	"permission_grants": ["spaces:docs", "hook:side-model"],
	"companion": {
		"label": "Whiteboard",
		"icon": "shapes"
	},
	"contributes": {
		"sidebar_sections": [
			{
				"id": "whiteboard",
				"title": "Whiteboard",
				"icon": "shapes",
				"spec": {
					"source": {
						"http": {
							"method": "GET",
							"path": "/api/apps/com.ryu.whiteboard/docs"
						},
						"items": "documents"
					},
					"itemTarget": "/spaces/{{item.space_id}}/app/com.ryu.whiteboard/{{item.id}}",
					"create": {
						"http": {
							"method": "POST",
							"path": "/api/apps/com.ryu.whiteboard/docs"
						},
						"targetFrom": "id",
						"label": "New whiteboard"
					},
					"itemActions": [
						{
							"id": "delete",
							"label": "Delete",
							"icon": "lucide:trash-2",
							"style": "danger",
							"http": {
								"method": "DELETE",
								"path": "/api/spaces/{{item.space_id}}/documents/{{item.id}}"
							}
						}
					]
				}
			}
		]
	}
}

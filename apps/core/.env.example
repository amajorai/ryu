# Ryu Core (apps/core) — environment configuration
#
# Core is the orchestration engine (Axum, http://127.0.0.1:7980). It has NO config
# file: every knob is a `RYU_*` environment variable (plus a handful of provider
# keys). EVERYTHING here is OPTIONAL — Core ships sensible, fully-local defaults and
# runs on install with none of these set. Nothing is hardcoded: each model, engine,
# embedder, reranker, TTS/STT, sandbox, and RAG strategy is a swappable default, not
# a lock. Set a var only to override a default.
#
# Convention below: `# NAME=` (commented) documents an override you can enable; a
# handful of canonical defaults are shown uncommented. Values shown after "default:"
# are the built-in fallback when the var is unset.
#
# OS-provided vars Core reads but you never set here: PATH, USERNAME, COMPUTERNAME,
# HOSTNAME (host/node-name auto-detection).

# ==============================================================================
# Bind / server / node identity
# ==============================================================================
# Address Core binds to. This is also the fail-closed gate: exposing beyond
# loopback is governed by this var (a `--bind=` flag cannot bypass it).
RYU_BIND=127.0.0.1:7980
# Bearer token required on protected API routes. Unset = no node auth (local only).
# RYU_TOKEN=
# Data directory root (db, models, plugins, spaces). Default: OS app-data dir.
# RYU_DIR=
# Extra CORS origins (comma-separated) added to the built-in desktop/web set.
# RYU_CORS_ORIGINS=
# Human-friendly node name (webhook relay, presence). Default: machine hostname.
# RYU_NODE_NAME=
# Publicly reachable URL of this node (control-plane registration).
# RYU_NODE_PUBLIC_URL=
# Ryu backend / identity+content plane base URL. Default: http://127.0.0.1:3000
# RYU_BACKEND_URL=
# Alias/override for the backend base URL used by cloud sync + gateway seeding.
# RYU_SERVER_URL=
# Managed-cloud control-plane base URL (credits, fleet). Falls back to RYU_SERVER_URL.
# RYU_CONTROL_PLANE_URL=
# Better Auth base URL used to verify node-user JWTs. Default: RYU_BACKEND_URL.
# RYU_AUTH_BASE_URL=
# BETTER_AUTH_URL=
# Master key (base64/hex) encrypting secrets at rest. Default: derived local key.
# RYU_MASTER_KEY=
# Multi-tenant scoping for a managed/cloud node.
# RYU_TEAM_ID=
# RYU_PROJECT_ID=
# Marks this as a managed cloud node (routes model traffic to the hosted fleet).
# RYU_MANAGED_NODE=
# Tool-exec approval mode for sandboxed/agent command execution (e.g. off/prompt).
# RYU_EXEC_APPROVAL_MODE=
# SSRF guard for agent HTTP egress (on by default); allowlist relaxes it.
# RYU_AGENT_EGRESS_SSRF_GUARD=
# RYU_AGENT_EGRESS_ALLOW_HOSTS=

# ==============================================================================
# Default + fallback LLM (the chat/utility model when no agent overrides it)
# ==============================================================================
# Default agent installed/selected. Default: ryu (Pi + Gateway flagship).
# RYU_DEFAULT_AGENT=ryu
# Model id for clean-context utility/sub-agent completions. Default: gpt-4o-mini.
# RYU_DEFAULT_LLM_MODEL=
# OpenAI-compatible base URL for the default LLM. Default: https://api.openai.com
# RYU_DEFAULT_LLM_BASE_URL=
# Bearer key for the default LLM (falls back to OPENAI_API_KEY).
# RYU_DEFAULT_LLM_API_KEY=
# Local fallback model when the primary provider fails. Default: gemma2.
# RYU_FALLBACK_LLM_MODEL=
# Fallback base URL (local llama.cpp). Default: http://127.0.0.1:8080
# RYU_FALLBACK_LLM_BASE_URL=
# RYU_FALLBACK_LLM_API_KEY=
# Fail-OPEN switch: allow a direct provider call when the Gateway is unreachable.
# RYU_ALLOW_GATEWAY_FALLBACK=
# Local llama.cpp chat server URL the managed gateway forwards to.
# LOCAL_LLM_URL=

# ==============================================================================
# Gateway link (Core runs the gateway as a managed sidecar and routes chat to it)
# ==============================================================================
# Gateway base URL (no trailing /v1). Default: http://127.0.0.1:7981
# RYU_GATEWAY_URL=
# Bearer token for the gateway when it runs with auth enabled.
# RYU_GATEWAY_TOKEN=
# Signing/data-plane key for a keyed/remote gateway.
# RYU_GATEWAY_KEY=
# Path/override for the gateway binary Core spawns.
# RYU_GATEWAY_BIN=
# Treat the gateway as externally managed (do not spawn a local one).
# RYU_GATEWAY_MANAGED=
# Remote data plane: keys live only in the hosted fleet; requires URL + TOKEN.
# RYU_GATEWAY_REMOTE=
# Path to a gateway config file passed through to the sidecar.
# GATEWAY_CONFIG=
# Seed the gateway firewall ON at first boot.
# GATEWAY_FIREWALL_ENABLED=
# Seed smart (classifier) model routing ON at first boot.
# GATEWAY_SMART_ROUTING_ENABLED=
# Inject OPENAI_BASE_URL/KEY into gateway-honoring ACP agents. Default: true.
# RYU_ACP_GATEWAY_INJECT=

# ==============================================================================
# Managed-cloud credits / billing (Core reads these to seed the gateway)
# ==============================================================================
# Enable credit metering + wallet enforcement on the gateway.
# GATEWAY_CREDITS_ENABLED=
# Credits/debit endpoint the gateway posts to.
# GATEWAY_CREDITS_URL=
# Shared secret for internal credit debit calls.
# RYU_CREDITS_INTERNAL_SECRET=
# Action when a wallet hits zero (e.g. stop/allow).
# GATEWAY_CREDITS_WALLET_EMPTY_ACTION=
# Per-tool-call cost in micro-USD.
# GATEWAY_CREDITS_COST_PER_TOOL_CALL_MICRO_USD=
# Free sandbox storage allowance (GiB) before metering.
# GATEWAY_CREDITS_SANDBOX_FREE_STORAGE_GIB=
# Sandbox billing markup in basis points.
# GATEWAY_CREDITS_SANDBOX_MARKUP_BPS=

# ==============================================================================
# Chat / local model registry (bundled defaults — all swappable)
# ==============================================================================
# Local chat GGUF id / weight URL / checksum (bundled Gemma). Default: built-in.
# RYU_LOCAL_CHAT_MODEL_ID=
# RYU_LOCAL_CHAT_MODEL_URL=
# RYU_LOCAL_CHAT_MODEL_SHA256=
# Path to the persisted registry.json (model/agent defaults).
# RYU_REGISTRY_PATH=
# Vision projector (mmproj) quantization for multimodal GGUFs.
# RYU_MMPROJ_QUANT=
# models.dev catalog URL for provider/model metadata.
# RYU_MODELS_DEV_URL=

# ==============================================================================
# Embeddings / reranker / RAG (local by default: nomic-embed + bge-reranker)
# ==============================================================================
# Embedding model id. Default: nomic-embed-text-v1.5 (llamacpp-embed sidecar).
# RYU_EMBED_MODEL=
# Remote embeddings base URL (unset = local llamacpp-embed on :8081).
# RYU_EMBED_BASE_URL=
# Bearer key for remote embeddings (falls back to OPENAI_API_KEY).
# RYU_EMBED_API_KEY=
# Embedding dimensionality override.
# RYU_EMBED_DIMS=
# Local embedding weight id / URL / checksum.
# RYU_LOCAL_EMBED_MODEL_ID=
# RYU_LOCAL_EMBED_MODEL_URL=
# RYU_LOCAL_EMBED_MODEL_SHA256=
# Reranker model id. Default: BAAI/bge-reranker.
# RYU_RERANKER_MODEL=
# Remote reranker base URL + key (unset = local).
# RYU_RERANKER_BASE_URL=
# RYU_RERANKER_API_KEY=
# Local reranker weight id / URL / checksum.
# RYU_LOCAL_RERANKER_MODEL_ID=
# RYU_LOCAL_RERANKER_MODEL_URL=
# RYU_LOCAL_RERANKER_MODEL_SHA256=
# Default RAG strategy: vector | graph. Default: vector.
# RYU_RAG_STRATEGY=
# GraphRAG entity-extraction model id.
# RYU_GRAPH_EXTRACTION_MODEL=
# Auto-recall of prior context into chat (semantic).
# RYU_AUTO_RECALL_ENABLED=
# Full-text-search recall complement.
# RYU_FTS_RECALL_ENABLED=
# Top-K memories injected on auto-recall.
# RYU_AUTO_RECALL_TOP_K=
# Max tokens of recalled context injected per turn.
# RYU_CONTEXT_MAX_TOKENS=

# ==============================================================================
# Local inference engines (weight/model overrides — pick per format)
# ==============================================================================
# RYU_WHISPER_MODEL=        # whisper.cpp STT model
# RYU_VLLM_MODEL=           # vLLM served model
# RYU_SGLANG_MODEL=         # SGLang served model
# RYU_MLX_MODEL=            # MLX (Apple) chat model
# RYU_MLX_VLM_MODEL=        # MLX vision model
# RYU_OMLX_MODEL_DIR=       # OpenMLX model directory
# RYU_SD_MODEL=             # stable-diffusion.cpp image model
# RYU_SILERO_VAD_MODEL_URL= # Silero VAD weight URL
# RYU_SILERO_VAD_MODEL_SHA256=
# RYU_PARAKEET_MODEL_URL=   # Parakeet STT weight URL

# ==============================================================================
# Voice: TTS / STT
# ==============================================================================
# TTS engine selector (e.g. kokoro/outetts). Default: bundled Kokoro.
# RYU_TTS_ENGINE=
# TTS runtime dirs / python interpreter.
# RYU_TTS_DIR=
# RYU_TTS_HF_HOME=
# RYU_TTS_PYTHON=
# Kokoro model + voices (weights and their download URLs).
# RYU_KOKORO_MODEL=
# RYU_KOKORO_MODEL_URL=
# RYU_KOKORO_VOICES=
# RYU_KOKORO_VOICES_URL=
# OuteTTS model + vocoder.
# RYU_OUTETTS_MODEL=
# RYU_OUTETTS_VOCODER=
# STT engine for chat voice input.
# RYU_STT_ENGINE=
# Route STT through the gateway to a hosted provider/model instead of local.
# RYU_STT_GATEWAY_PROVIDER=
# RYU_STT_GATEWAY_MODEL=
# STT engine used when transcribing recorded clips.
# RYU_CLIP_STT_ENGINE=

# ==============================================================================
# MCP / tools / execution
# ==============================================================================
# MCP registry URL for the catalog.
# RYU_MCP_REGISTRY_URL=
# Path to a static MCP server config.
# RYU_MCP_CONFIG=
# Global MCP tool allowlist. Per-agent override: RYU_MCP_ALLOWLIST_<AGENT_ID>.
# RYU_MCP_ALLOWLIST=
# Binary overrides for bundled tool sidecars.
# RYU_SPIDER_BIN=           # spider (scraper)
# RYU_RTK_BIN=              # rtk token-killer
# RYU_BUN_BIN=              # bun (securexec tool backend)
# RYU_DENO_BIN=             # deno (PTC/tool sandbox backend)
# Exa search MCP.
# RYU_EXA_API_KEY=
# RYU_EXA_BASE_URL=
# Tool-exec sandbox: work dir + per-exec memory cap (MB).
# RYU_SECUREXEC_DIR=
# RYU_TOOL_EXEC_MEMORY_MB=
# Which chat tools the apps layer exposes.
# RYU_APPS_CHAT_TOOLS=

# ==============================================================================
# Sandbox backends (default: wasmtime in-process; others opt-in / auto-detect)
# ==============================================================================
# Backend selector (wasmtime | docker | daytona | microsandbox | opensandbox).
# RYU_SANDBOX_BACKEND=
# Disable the sandbox entirely.
# RYU_SANDBOX_DISABLED=
# Docker backend.
# RYU_SANDBOX_DOCKER_BINARY=
# RYU_SANDBOX_DOCKER_IMAGE=
# RYU_SANDBOX_DOCKER_DETECT_SECS=
# microsandbox backend.
# RYU_SANDBOX_MICROSANDBOX_BINARY=
# RYU_SANDBOX_MICROSANDBOX_IMAGE=
# RYU_SANDBOX_MICROSANDBOX_DETECT_SECS=
# opensandbox backend.
# RYU_SANDBOX_OPENSANDBOX_BINARY=
# RYU_SANDBOX_OPENSANDBOX_IMAGE=
# RYU_SANDBOX_OPENSANDBOX_TIMEOUT=
# RYU_SANDBOX_OPENSANDBOX_DETECT_SECS=
# Daytona cloud sandbox (billed compute).
# RYU_SANDBOX_DAYTONA_URL=
# RYU_SANDBOX_DAYTONA_TOKEN=      # or DAYTONA_API_KEY
# DAYTONA_API_KEY=
# RYU_SANDBOX_DAYTONA_TARGET=
# RYU_SANDBOX_DAYTONA_SNAPSHOT=
# RYU_SANDBOX_DAYTONA_TIMEOUT_SECS=
# RYU_SANDBOX_DAYTONA_VCPU=
# RYU_SANDBOX_DAYTONA_MEM_GIB=
# RYU_SANDBOX_DAYTONA_STORAGE_GIB=
# RYU_SANDBOX_DAYTONA_OS=
# RYU_SANDBOX_DAYTONA_GPU=
# RYU_SANDBOX_DAYTONA_GPU_COUNT=

# ==============================================================================
# Ghost / Shadow / Restate / research tool sidecars
# ==============================================================================
# Ghost desktop-automation MCP release URL override.
# RYU_GHOST_RELEASE_URL=
# Shadow (screen/audio capture) service URL + release + its own LLM.
# RYU_SHADOW_URL=
# RYU_SHADOW_RELEASE_URL=
# SHADOW_LLM_BASE_URL=
# SHADOW_LLM_MODEL=
# SHADOW_LLM_API_KEY=
# Speaker-diarization service URL (meetings).
# RYU_DIARIZE_URL=
# Restate durable-execution admin URL + version (legacy; in-process engine is default).
# RYU_RESTATE_ADMIN_URL=
# RYU_RESTATE_VERSION=
# yt-dlp downloader version / URL.
# RYU_YTDLP_VERSION=
# RYU_YTDLP_URL=
# Deep-research tool: workspace dir + python interpreter.
# RESEARCH_DIR=
# RESEARCH_PYTHON=

# ==============================================================================
# Skills
# ==============================================================================
# Skills directory + active-skills file.
# RYU_SKILLS_DIR=
# RYU_SKILLS_ACTIVE_FILE=
# Progressive-disclosure mode for skills.
# RYU_SKILLS_DISCLOSURE=
# Author identity stamped on skills you create.
# RYU_SKILLS_AUTHOR=
# skills.sh catalog API URL.
# SKILLS_SH_API_URL=

# ==============================================================================
# Plugins / apps / marketplace + catalog federation
# ==============================================================================
# Plugin + app install directories.
# RYU_PLUGINS_DIR=
# RYU_APPS_DIR=
# App/plugin registry URL.
# RYU_APP_REGISTRY_URL=
# Stub grant validation (dev only — bypasses real permission checks).
# RYU_STUB_GRANT_VALIDATION=
# RYU_STUB_SELF_BUILD_GRANTS=
# Catalog source overrides.
# RYU_CATALOG_SOURCES_FILE=
# Marketplace (git-standard) repo + hosted API + publish token + verify key.
# RYU_MARKETPLACE_REPO=
# Marketplace API base URL. Defaults to the hosted control plane
# (https://api.ryuhq.com); set to http://localhost:3000 for local dev / self-host.
# RYU_MARKETPLACE_API_URL=
# RYU_MARKETPLACE_TOKEN=
# RYU_MARKETPLACE_PUBLIC_KEY=
# Hosted MCP index for the catalog.
# RYU_HOSTED_MCP_INDEX_URL=
# integrations.sh (Composio-style) API/raw URLs + cache TTL.
# RYU_INTEGRATIONS_SH_API_URL=
# RYU_INTEGRATIONS_SH_RAW_OPENAPI_URL=
# RYU_INTEGRATIONS_SH_CACHE_TTL_SECS=
# Smithery MCP registry key.
# SMITHERY_API_KEY=

# ==============================================================================
# Chat power-feature models & judges (each falls back to the default LLM)
# ==============================================================================
# RYU_ADVISOR_MODEL=            # /advisor stronger-reviewer model
# RYU_BTW_MODEL=                # /btw side-question model
# RYU_BTW_EFFORT=               # /btw reasoning effort
# RYU_PREDICT_MODEL=            # predictive-typing model
# RYU_WHITEBOARD_MODEL=         # whiteboard AI-generation model
# RYU_WHITEBOARD_EFFORT=
# RYU_MEETING_NOTES_MODEL=      # meeting-notes summarizer model
# RYU_MEETING_NOTES_EFFORT=
# RYU_MEETING_NOTES_MAX_CHARS=  # transcript cap fed to the summarizer
# RYU_QUEST_JUDGE_MODEL=        # quest auto-detect judge model
# RYU_QUEST_JUDGE_EFFORT=
# RYU_QUEST_INTERVAL=           # quest detection interval (secs)

# ==============================================================================
# Continual learning
# ==============================================================================
# RYU_LEARNING_ENABLED=         # master switch (default off)
# RYU_LEARNING_SKILLS_ENABLED=  # skill synthesis from experience
# RYU_LEARNING_INTERVAL=        # learning-loop interval (secs)
# RYU_LEARNING_PRM_MODEL=       # process-reward model (falls back to default LLM)
# RYU_LEARNING_SYNTH_MODEL=     # synthesis model (falls back to default LLM)

# ==============================================================================
# Provider API keys (BYOK — all optional; absent keys degrade cleanly)
# ==============================================================================
# OpenAI (also the fallback key for default LLM + embeddings).
# OPENAI_API_KEY=
# Anthropic (Pi provider catalog + gateway upstream).
# ANTHROPIC_API_KEY=
# Pi provider catalog keys (apps/core/src/pi_config/mod.rs — all optional BYOK).
# GEMINI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# CEREBRAS_API_KEY=
# FIREWORKS_API_KEY=
# TOGETHER_API_KEY=
# NVIDIA_API_KEY=
# MOONSHOT_API_KEY=
# ZAI_API_KEY=
# MINIMAX_API_KEY=
# OpenRouter (RYU_ prefixed takes precedence over the bare name).
# RYU_OPENROUTER_API_KEY=
# OPENROUTER_API_KEY=
# Opt into OpenRouter prompt/data collection ("1" to allow).
# OPENROUTER_DATA_COLLECTION=
# Hugging Face token (gated model downloads).
# HF_TOKEN=
# fal.ai image/media (RYU_ prefixed wins; FAL_KEY also accepted).
# RYU_FAL_API_KEY=
# FAL_API_KEY=
# FAL_KEY=
# Replicate image/media.
# RYU_REPLICATE_API_KEY=
# REPLICATE_API_KEY=
# Composio integrations (RYU_ prefixed wins).
# RYU_COMPOSIO_API_KEY=
# COMPOSIO_API_KEY=
# COMPOSIO_BASE_URL=
# COMPOSIO_ENTITY_ID=
# COMPOSIO_WEBHOOK_SECRET=
# GIF search: provider (default klipy) + key. Provider-specific keys also read:
# TENOR_API_KEY / GIPHY_API_KEY / KLIPY_API_KEY.
# RYU_GIF_PROVIDER=
# RYU_GIF_API_KEY=
# TENOR_API_KEY=
# GIPHY_API_KEY=
# KLIPY_API_KEY=
# Artificial Analysis model-benchmark data (RYU_ prefixed alias accepted).
# ARTIFICIAL_ANALYSIS_API_KEY=
# RYU_AA_API_KEY=
# Pi agent OAuth client/token endpoints (for BYO-subscription Anthropic/OpenAI login).
# RYU_PI_OAUTH_ANTHROPIC_CLIENT_ID=
# RYU_PI_OAUTH_ANTHROPIC_TOKEN_URL=
# RYU_PI_OAUTH_OPENAI_CLIENT_ID=
# RYU_PI_OAUTH_OPENAI_TOKEN_URL=

# ==============================================================================
# Identity vault
# ==============================================================================
# Default identity source id.
# RYU_IDENTITY_DEFAULT_SOURCE=
# Identity-health check interval (secs).
# RYU_IDENTITY_HEALTH_INTERVAL=

# ==============================================================================
# Email / SMTP (agent + notification egress)
# ==============================================================================
# RYU_SMTP_HOST=
# RYU_SMTP_PORT=
# RYU_SMTP_USERNAME=
# RYU_SMTP_PASSWORD=
# RYU_SMTP_FROM=
# RYU_SMTP_STARTTLS=

# ==============================================================================
# Mesh networking (Tailscale, fail-closed) + webhook ingress
# ==============================================================================
# Enable the mesh (required; fail-closed when tokenless).
# RYU_MESH_ENABLED=
# RYU_MESH_AUTHKEY=
# RYU_MESH_LOGIN_SERVER=
# RYU_MESH_SOCKS5_ADDR=
# RYU_MESH_HTTP_PROXY_ADDR=
# Tailscale binary overrides.
# RYU_TAILSCALE_BIN=
# RYU_TAILSCALED_BIN=
# Public URL for inbound webhook ingress.
# RYU_WEBHOOK_INGRESS_URL=

# ==============================================================================
# Hardware companion nodes
# ==============================================================================
# RYU_HARDWARE_NODE_URL=
# RYU_HARDWARE_ALLOWED_HOSTS=

# ==============================================================================
# Spaces / media / downloads
# ==============================================================================
# Encryption key for Spaces content.
# RYU_SPACES_KEY=
# Enable wiki link expansion in Spaces.
# RYU_SPACES_LINK_EXPANSION=
# Media output directory (generated images/audio).
# RYU_MEDIA_DIR=
# Download manager state files + behavior.
# RYU_DOWNLOADS_FILE=
# RYU_DOWNLOADS_HISTORY_FILE=
# RYU_DOWNLOADS_AUTORESUME=
# RYU_MAX_CONCURRENT_DOWNLOADS=

# ==============================================================================
# Fine-tuning (Unsloth LoRA/QLoRA sidecar)
# ==============================================================================
# RYU_UNSLOTH_DIR=
# RYU_UNSLOTH_HF_HOME=
# RYU_UNSLOTH_OUTPUT_DIR=
# RYU_UNSLOTH_PYTHON=

# ==============================================================================
# Cloud sync / headroom / Pi + external agent homes
# ==============================================================================
# Enable cross-device SyncClient.
# RYU_SYNC_ENABLED=
# Headroom (community savings telemetry) service.
# RYU_HEADROOM_ENABLED=
# RYU_HEADROOM_URL=
# RYU_HEADROOM_MANAGED=
# RYU_HEADROOM_BIN=
# Pi agent config directory.
